@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject ApiClient ApiClient

<MudThemeProvider @ref="_themeProvider" Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudXProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true" Class="appbar-blur">
        <MudIconButton Icon="@(_drawerOpen ? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu)"
                       Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="ToggleDrawer"
                       Class="hamburger-btn" />
        <a href="/" style="display:flex;align-items:center;text-decoration:none;color:inherit;cursor:pointer;">
            <MudIcon Icon="@Icons.Material.Filled.AutoStories" Class="ml-2" />
            <MudText Class="ml-2 appbar-title">Pathfinder Campaign Tracker</MudText>
        </a>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="@(_isDarkMode ? "Naar lichtmodus" : "Naar donkermodus")">
                    <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                                   Color="Color.Inherit" OnClick="ToggleTheme"
                                   Class="theme-toggle-btn" />
                </MudTooltip>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                         Class="mx-1" Icon="@Icons.Material.Filled.Person">
                    @context.User.Identity?.Name
                </MudChip>
                <MudTooltip Text="Afmelden">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                                   OnClick="@(() => Navigation.NavigateTo("/logout", forceLoad: true))" />
                </MudTooltip>
            </Authorized>
            <NotAuthorized>
                <MudTooltip Text="@(_isDarkMode ? "Naar lichtmodus" : "Naar donkermodus")">
                    <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                                   Color="Color.Inherit" OnClick="ToggleTheme"
                                   Class="theme-toggle-btn" />
                </MudTooltip>
                <MudButton Href="/login" Color="Color.Inherit" Variant="Variant.Text">Inloggen</MudButton>
                <MudButton Href="/register" Color="Color.Inherit" Variant="Variant.Text">Registreren</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" ClipMode="DrawerClipMode.Always"
               Class="drawer-animate" Variant="DrawerVariant.Responsive">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4 page-enter">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Er is een onverwerkte fout opgetreden.
    <a href="." class="reload">Herladen</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    private MudThemeProvider _themeProvider = null!;
    private bool _isDarkMode;
    private bool _darkModeInitialized;
    private bool _isAuthenticated;
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#8B1A1A",
            PrimaryContrastText = "#F5EDD6",
            Secondary = "#B8860B",
            SecondaryContrastText = "#1A0A00",
            AppbarBackground = "#6B1212",
            AppbarText = "#F5EDD6",
            Background = "#F2E8CE",
            BackgroundGray = "#E8D9B0",
            Surface = "#FAF4E4",
            DrawerBackground = "#2D1A0A",
            DrawerText = "#E8D099",
            DrawerIcon = "#C8A951",
            TextPrimary = "#1A0A00",
            TextSecondary = "#5C3D1E",
            LinesDefault = "rgba(139, 26, 26, 0.2)",
            LinesInputs = "rgba(139, 26, 26, 0.35)",
            Divider = "rgba(139, 26, 26, 0.2)",
            TableStriped = "#EDE0C0",
            OverlayDark = "rgba(26, 10, 0, 0.55)",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#D4AF37",
            PrimaryContrastText = "#0D0806",
            Secondary = "#C41E3A",
            SecondaryContrastText = "#F5EDD6",
            AppbarBackground = "#0D0806",
            AppbarText = "#D4AF37",
            Background = "#0D0806",
            BackgroundGray = "#1A0E06",
            Surface = "#1A0E06",
            DrawerBackground = "#100800",
            DrawerText = "#C8A951",
            DrawerIcon = "#C8A951",
            TextPrimary = "#F5EDD6",
            TextSecondary = "#C8A951",
            LinesDefault = "rgba(212, 175, 55, 0.2)",
            LinesInputs = "rgba(212, 175, 55, 0.35)",
            Divider = "rgba(212, 175, 55, 0.15)",
            TableStriped = "#1A0E06",
            OverlayDark = "rgba(0, 0, 0, 0.72)",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["'Crimson Text'", "'Georgia'", "'Times New Roman'", "serif"],
                FontSize = "1.0625rem",
                LineHeight = "1.6",
            },
            H1 = new H1Typography { FontFamily = ["'Cinzel'", "'Georgia'", "serif"], FontWeight = "700" },
            H2 = new H2Typography { FontFamily = ["'Cinzel'", "'Georgia'", "serif"], FontWeight = "700" },
            H3 = new H3Typography { FontFamily = ["'Cinzel'", "'Georgia'", "serif"], FontWeight = "600" },
            H4 = new H4Typography { FontFamily = ["'Cinzel'", "'Georgia'", "serif"], FontWeight = "600" },
            H5 = new H5Typography { FontFamily = ["'Cinzel'", "'Georgia'", "serif"], FontWeight = "600" },
            H6 = new H6Typography { FontFamily = ["'Cinzel'", "'Georgia'", "serif"], FontWeight = "600" },
            Overline = new OverlineTypography { FontFamily = ["'Cinzel'", "serif"], LetterSpacing = "0.12em" },
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "4px"
        }
    };

    private void ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        if (_isAuthenticated)
            _ = ApiClient.SetDarkModeAsync(_isDarkMode);
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
        if (_isAuthenticated)
        {
            var claim = authState.User.FindFirst("dark_mode")?.Value;
            _isDarkMode = claim == "true";
            _darkModeInitialized = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_darkModeInitialized)
        {
            _darkModeInitialized = true;
        }
        await base.OnAfterRenderAsync(firstRender);
    }
}

