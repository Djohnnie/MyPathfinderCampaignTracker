@inject ApiClient ApiClient
@inject FavoriteCampaignState FavoriteCampaignState
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<MudNavMenu Class="mt-2">
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">
                Dashboard
            </MudNavLink>

            @if (FavoriteCampaignState.CampaignId.HasValue)
            {
                <div class="fantasy-divider mx-3 mt-3">@FavoriteCampaignState.CampaignTitle</div>
                <MudNavLink Href="@($"/campaigns/{FavoriteCampaignState.CampaignId}")" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">
                    Overzicht
                </MudNavLink>
                <MudNavLink Href="@($"/campaigns/{FavoriteCampaignState.CampaignId}/characters")" Icon="@Icons.Material.Filled.Shield">
                    Karakters
                </MudNavLink>
                <MudNavLink Href="@($"/campaigns/{FavoriteCampaignState.CampaignId}/recaps")" Icon="@Icons.Material.Filled.MenuBook">
                    Recaps
                </MudNavLink>
                <MudNavLink Href="@($"/campaigns/{FavoriteCampaignState.CampaignId}/chat")" Icon="@Icons.Material.Filled.Chat">
                    Chat
                </MudNavLink>
                <MudNavLink Href="@($"/campaigns/{FavoriteCampaignState.CampaignId}/sessions")" Icon="@Icons.Material.Filled.CalendarMonth">
                    Sessies
                </MudNavLink>
                <MudNavLink Href="@($"/campaigns/{FavoriteCampaignState.CampaignId}/notes")" Icon="@Icons.Material.Filled.StickyNote2">
                    Notities
                </MudNavLink>
                <MudNavLink Href="@($"/campaigns/{FavoriteCampaignState.CampaignId}/loreacle")" Icon="@Icons.Material.Filled.AutoAwesome">
                    Loreacle
                </MudNavLink>
            }

            <div class="fantasy-divider mx-3 mt-3">Mijn Overzicht</div>
            <MudNavLink Href="/my/campaigns" Icon="@Icons.Material.Filled.Map">
                Mijn campagnes
            </MudNavLink>
            <MudNavLink Href="/my/characters" Icon="@Icons.Material.Filled.Shield">
                Mijn karakters
            </MudNavLink>
            <MudNavLink Href="/my/recaps" Icon="@Icons.Material.Filled.MenuBook">
                Mijn recaps
            </MudNavLink>

            <AuthorizeView Roles="Admin" Context="adminCtx">
                <Authorized>
                    <div class="fantasy-divider mx-3 mt-3">Beheer</div>
                    <MudNavLink Href="/admin/campaigns" Icon="@Icons.Material.Filled.Map">
                        Campagnebeheer
                    </MudNavLink>
                    <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.ManageAccounts">
                        Gebruikersbeheer
                    </MudNavLink>
                </Authorized>
            </AuthorizeView>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="/login" Icon="@Icons.Material.Filled.Login">Inloggen</MudNavLink>
            <MudNavLink Href="/register" Icon="@Icons.Material.Filled.PersonAdd">Registreren</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    protected override async Task OnInitializedAsync()
    {
        FavoriteCampaignState.OnChange += StateHasChanged;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true && !FavoriteCampaignState.IsLoaded)
        {
            var fav = await ApiClient.GetFavoriteCampaignAsync();
            FavoriteCampaignState.Set(fav?.Id, fav?.Title);
        }
    }

    public void Dispose() => FavoriteCampaignState.OnChange -= StateHasChanged;
}
