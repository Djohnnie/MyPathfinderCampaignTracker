<MudNavMenu Class="mt-2">
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">
                Dashboard
            </MudNavLink>

            <div class="fantasy-divider mx-3 mt-3">Mijn Overzicht</div>
            <MudNavLink Href="/my/campaigns" Icon="@Icons.Material.Filled.Map">
                Mijn campagnes
            </MudNavLink>
            <MudNavLink Href="/my/characters" Icon="@Icons.Material.Filled.Shield">
                Mijn personages
            </MudNavLink>
            <MudNavLink Href="/my/recaps" Icon="@Icons.Material.Filled.MenuBook">
                Mijn terugblikken
            </MudNavLink>

            <AuthorizeView Roles="Admin" Context="adminCtx">
                <Authorized>
                    <div class="fantasy-divider mx-3 mt-3">Beheer</div>
                    <MudNavLink Href="/admin/campaigns" Icon="@Icons.Material.Filled.Map">
                        Campagnebeheer
                    </MudNavLink>
                    <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.ManageAccounts">
                        Gebruikersbeheer
                    </MudNavLink>
                </Authorized>
            </AuthorizeView>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="/login" Icon="@Icons.Material.Filled.Login">Inloggen</MudNavLink>
            <MudNavLink Href="/register" Icon="@Icons.Material.Filled.PersonAdd">Registreren</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

