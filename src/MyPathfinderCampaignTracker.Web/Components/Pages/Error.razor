@page "/Error"
@using System.Diagnostics

<PageTitle>Fout — Pathfinder Campaign Tracker</PageTitle>

<h1 class="text-danger">Fout.</h1>
<h2 class="text-danger">Er is een fout opgetreden bij het verwerken van uw aanvraag.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>Aanvraag-ID:</strong> <code>@RequestId</code>
    </p>
}

<h3>Ontwikkelaarsmodus</h3>
<p>
    Overschakelen naar de <strong>Development</strong>-omgeving toont meer gedetailleerde informatie over de opgetreden fout.
</p>
<p>
    <strong>De Development-omgeving mag niet worden ingeschakeld voor geïmplementeerde applicaties.</strong>
    Dit kan leiden tot het weergeven van gevoelige informatie aan eindgebruikers.
    Schakel voor lokaal debuggen de <strong>Development</strong>-omgeving in door de omgevingsvariabele <strong>ASPNETCORE_ENVIRONMENT</strong> in te stellen op <strong>Development</strong>
    en de app opnieuw te starten.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
