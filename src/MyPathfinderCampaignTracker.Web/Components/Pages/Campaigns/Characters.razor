@page "/campaigns/{CampaignId:guid}/characters"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@using System.Security.Claims

<PageTitle>Karakters — Pathfinder Campaign Tracker</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else
{
    <div class="d-flex align-center mb-2" style="gap: 12px;">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default"
                       OnClick="@(() => Navigation.NavigateTo($"/campaigns/{CampaignId}"))" />
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 700;">Karakters</MudText>
            @if (_campaignTitle is not null)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_campaignTitle</MudText>
            }
        </div>
    </div>

    <div class="d-flex justify-end mb-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenCreateDialog" Style="text-transform: none; font-weight: 600;">
            Nieuw Karakter
        </MudButton>
    </div>

    @if (_characters.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center"
                  Style="border: 1px dashed var(--mud-palette-lines-default);">
            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">Nog geen Karakters</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Klik op "Nieuw Karakter" om te beginnen.</MudText>
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var character in _characters)
            {
                <MudItem xs="12" md="6" xl="4">
                    <MudPaper Elevation="0" Class="pa-4 card-hover" Style="border: 1px solid var(--mud-palette-lines-default);">
        @* Header *@
                        <div class="d-flex align-center justify-space-between mb-3">
                            <div class="d-flex align-center" style="gap: 12px;">
                                @if (_photoCache.TryGetValue(character.Id, out var avatarSrc) && avatarSrc is not null)
                                {
                                    <img src="@avatarSrc" style="width: 56px; height: 56px; border-radius: 50%; flex-shrink: 0;" alt="Avatar" />
                                }
                                else
                                {
                                    <MudAvatar Color="Color.Primary" Style="width: 56px; height: 56px; flex-shrink: 0; font-size: 1.4rem;">@character.Name.FirstOrDefault()</MudAvatar>
                                }
                                <div>
                                    <div class="d-flex align-center" style="gap: 8px;">
                                        <MudText Typo="Typo.h6" Style="font-weight: 700;">@character.Name</MudText>
                                        @if (character.KilledInAction)
                                        {
                                            <MudChip T="string" Color="Color.Error" Size="Size.Small"
                                                     Icon="@Icons.Material.Filled.Dangerous">KIA</MudChip>
                                        }
                                    </div>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @character.Race · @character.CharacterClass · Niveau @character.Level
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Speler: @character.OwnerUsername.CapFirst()
                                    </MudText>
                                </div>
                            </div>
                            @if (CanEdit(character))
                            {
                                <div>
                                    <MudTooltip Text="Bewerken">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       Color="Color.Primary" OnClick="@(() => OpenEditDialog(character))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Verwijderen">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error" OnClick="@(() => OpenDeleteDialog(character))" />
                                    </MudTooltip>
                                </div>
                            }
                        </div>

                        @* Ability scores *@
                        <div class="d-flex justify-space-between mb-3" style="gap: 4px;">
                            @foreach (var (label, score) in AbilityScores(character))
                            {
                                <div class="d-flex flex-column align-center pa-2"
                                     style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px; flex: 1;">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;">
                                        @label
                                    </MudText>
                                    <MudText Typo="Typo.h6" Style="font-weight: 700; line-height: 1.2;">@score</MudText>
                                    <MudText Typo="Typo.caption" Color="@(Modifier(score) >= 0 ? Color.Success : Color.Error)">
                                        @(Modifier(score) >= 0 ? $"+{Modifier(score)}" : Modifier(score).ToString())
                                    </MudText>
                                </div>
                            }
                        </div>

                        @* Backstory snippet *@
                        @if (!string.IsNullOrWhiteSpace(character.Backstory))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-style: italic;" Class="mt-2">
                                @(character.Backstory.Length > 100 ? character.Backstory[..100] + "…" : character.Backstory)
                            </MudText>
                        }

                        @* Story info chips *@
                        @if (!string.IsNullOrWhiteSpace(character.Alignment) || !string.IsNullOrWhiteSpace(character.Languages))
                        {
                            <div class="d-flex flex-wrap mt-2" style="gap: 4px;">
                                @if (!string.IsNullOrWhiteSpace(character.Alignment))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">
                                        @character.Alignment
                                    </MudChip>
                                }
                                @if (!string.IsNullOrWhiteSpace(character.Languages))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                                        @character.Languages
                                    </MudChip>
                                }
                            </div>
                        }
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
}

@* ─── Create / Edit Dialog ─── *@
<CharacterDialog @bind-IsOpen="_dialogOpen"
                 EditingId="_editingId"
                 Form="_form"
                 Saving="_saving"
                 SelectedPhoto="_selectedPhoto"
                 SelectedPhotoChanged="@(f => _selectedPhoto = f)"
                 PhotoCache="_photoCache"
                 OnClose="CloseDialog"
                 OnSave="SaveCharacter" />

@* ─── Delete Confirm Dialog ─── *@
<MudDialog @bind-Visible="_deleteDialogOpen" Options="_deleteDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Karakter verwijderen</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Weet u zeker dat u <strong>@_deletingCharacter?.Name</strong> wilt verwijderen?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _deleteDialogOpen = false)" Variant="Variant.Text"
                   Style="text-transform: none;">Annuleren</MudButton>
        <MudButton OnClick="ConfirmDelete" Variant="Variant.Filled" Color="Color.Error"
                   Disabled="_saving" Style="text-transform: none; font-weight: 600;">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Verwijderen
        </MudButton>
    </DialogActions>
</MudDialog>


@code {
    [Parameter] public Guid CampaignId { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private List<CharacterDto> _characters = [];
    private string? _campaignTitle;
    private bool _loading = true;

    private Guid _currentUserId;
    private bool _isAdmin;

    // Create/Edit dialog
    private bool _dialogOpen;
    private Guid? _editingId;
    private CharacterDialog.CharacterFormModel _form = new();
    private bool _saving;
    private IBrowserFile? _selectedPhoto;

    // Photo cache: characterId -> data URI
    private Dictionary<Guid, string?> _photoCache = new();

    // Delete dialog
    private bool _deleteDialogOpen;
    private CharacterDto? _deletingCharacter;

    private readonly DialogOptions _deleteDialogOptions = new()
    {
        MaxWidth = MaxWidth.ExtraSmall,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        Guid.TryParse(userIdClaim, out _currentUserId);
        _isAdmin = authState.User.IsInRole("Admin");

        var campaign = await ApiClient.GetCampaignAsync(CampaignId);
        _campaignTitle = campaign?.Title;

        await LoadCharactersAsync();
        _loading = false;
    }

    private async Task LoadCharactersAsync()
    {
        _characters = await ApiClient.GetCharactersAsync(CampaignId);
        await LoadPhotosAsync();
    }

    private async Task LoadPhotosAsync()
    {
        var tasks = _characters
            .Where(c => c.HasPhoto)
            .Select(async c =>
            {
                var bytes = await ApiClient.GetCharacterPhotoAsync(c.Id);
                if (bytes is not null)
                    _photoCache[c.Id] = $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
            });
        await Task.WhenAll(tasks);
    }

    private bool CanEdit(CharacterDto character) =>
        character.UserId == _currentUserId || _isAdmin;

    private void OpenCreateDialog()
    {
        _editingId = null;
        _form = new CharacterDialog.CharacterFormModel();
        _selectedPhoto = null;
        _dialogOpen = true;
    }

    private void OpenEditDialog(CharacterDto character)
    {
        _editingId = character.Id;
        _selectedPhoto = null;
        _form = new CharacterDialog.CharacterFormModel
        {
            Name = character.Name,
            Race = character.Race,
            CharacterClass = character.CharacterClass,
            Level = character.Level,
            Backstory = character.Backstory,
            Strength = character.Strength,
            Dexterity = character.Dexterity,
            Constitution = character.Constitution,
            Intelligence = character.Intelligence,
            Wisdom = character.Wisdom,
            Charisma = character.Charisma,
            KilledInAction = character.KilledInAction,
            Alignment = character.Alignment,
            Personality = character.Personality,
            IdealsAndGoals = character.IdealsAndGoals,
            Flaws = character.Flaws,
            Languages = character.Languages,
            Appearance = character.Appearance
        };
        _dialogOpen = true;
    }

    private void CloseDialog()
    {
        _dialogOpen = false;
        _selectedPhoto = null;
    }

    private async Task SaveCharacter()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            Snackbar.Add("Naam is verplicht.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            var request = new CharacterRequest(
                _form.Name.Trim(),
                _form.Race.Trim(),
                _form.CharacterClass.Trim(),
                _form.Level,
                _form.Backstory.Trim(),
                _form.Strength,
                _form.Dexterity,
                _form.Constitution,
                _form.Intelligence,
                _form.Wisdom,
                _form.Charisma,
                _form.KilledInAction,
                string.IsNullOrWhiteSpace(_form.Alignment) ? null : _form.Alignment.Trim(),
                string.IsNullOrWhiteSpace(_form.Personality) ? null : _form.Personality.Trim(),
                string.IsNullOrWhiteSpace(_form.IdealsAndGoals) ? null : _form.IdealsAndGoals.Trim(),
                string.IsNullOrWhiteSpace(_form.Flaws) ? null : _form.Flaws.Trim(),
                string.IsNullOrWhiteSpace(_form.Languages) ? null : _form.Languages.Trim(),
                string.IsNullOrWhiteSpace(_form.Appearance) ? null : _form.Appearance.Trim());

            if (_editingId.HasValue)
            {
                var ok = await ApiClient.UpdateCharacterAsync(_editingId.Value, request);
                if (ok && _selectedPhoto is not null)
                    await ApiClient.UploadCharacterPhotoAsync(_editingId.Value, _selectedPhoto);
                Snackbar.Add(ok ? "Karakter bijgewerkt." : "Bijwerken mislukt.", ok ? Severity.Success : Severity.Error);
            }
            else
            {
                var created = await ApiClient.CreateCharacterAsync(CampaignId, request);
                if (created is not null && _selectedPhoto is not null)
                    await ApiClient.UploadCharacterPhotoAsync(created.Id, _selectedPhoto);
                Snackbar.Add(created is not null ? "Karakter aangemaakt." : "Aanmaken mislukt.",
                    created is not null ? Severity.Success : Severity.Error);
            }

            _dialogOpen = false;
            await LoadCharactersAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private void OpenDeleteDialog(CharacterDto character)
    {
        _deletingCharacter = character;
        _deleteDialogOpen = true;
    }

    private async Task ConfirmDelete()
    {
        if (_deletingCharacter is null) return;
        _saving = true;
        try
        {
            var ok = await ApiClient.DeleteCharacterAsync(_deletingCharacter.Id);
            _deleteDialogOpen = false;
            Snackbar.Add(ok ? "Karakter verwijderd." : "Verwijderen mislukt.", ok ? Severity.Success : Severity.Error);
            if (ok) await LoadCharactersAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private static int Modifier(int score) => (int)Math.Floor((score - 10) / 2.0);

    private static IEnumerable<(string Label, int Score)> AbilityScores(CharacterDto c) =>
    [
        ("STR", c.Strength),
        ("DEX", c.Dexterity),
        ("CON", c.Constitution),
        ("INT", c.Intelligence),
        ("WIS", c.Wisdom),
        ("CHA", c.Charisma)
    ];
}
