@page "/campaigns/{Id:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Security.Claims
@using System.Runtime.InteropServices
@inject ApiClient ApiClient
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject FavoriteCampaignState FavoriteCampaignState
<PageTitle>@(_campaign?.Title ?? "Campagne") — Pathfinder Campaign Tracker</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_campaign is null)
{
    <MudAlert Severity="Severity.Error">Campagne niet gevonden of u heeft geen toegang.</MudAlert>
}
else
{
    <div class="d-flex align-center mb-2" style="gap: 12px;">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default"
                       OnClick="@(() => Navigation.NavigateTo("/dashboard"))" />
        <MudText Typo="Typo.h4" Style="font-weight: 700;">@_campaign.Title</MudText>
        @if (_campaign.EndDate.HasValue && _campaign.EndDate < DateTime.UtcNow)
        {
            <MudChip T="string" Color="Color.Default" Size="Size.Small">Afgelopen</MudChip>
        }
        else
        {
            <MudChip T="string" Color="Color.Success" Size="Size.Small">Actief</MudChip>
        }
        <MudTooltip Text="@(_favoriteCampaignId == _campaign.Id ? "Verwijder favoriet" : "Markeer als favoriet")">
            <MudIconButton Icon="@(_favoriteCampaignId == _campaign.Id ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                           Color="@(_favoriteCampaignId == _campaign.Id ? Color.Error : Color.Default)"
                           OnClick="ToggleFavoriteAsync" />
        </MudTooltip>
    </div>

    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="@(_isEditingDescription ? "mb-2" : "mb-6")">
        @if (_isEditingDescription)
        {
            <div>
                <MudTextField @bind-Value="_editDescriptionValue" Variant="Variant.Outlined" Lines="3"
                              Label="Beschrijving" Class="mb-2" Style="font-family: inherit;" />
                <div class="d-flex align-center" style="gap: 8px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="SaveDescriptionAsync" Disabled="_isSavingDescription"
                               Style="text-transform: none; font-weight: 600;">
                        @if (_isSavingDescription)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                        }
                        Opslaan
                    </MudButton>
                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="CancelEditDescription"
                               Style="text-transform: none;">Annuleren</MudButton>
                    <MudTooltip Text="Vertalen naar Nederlands">
                        <MudIconButton Icon="@Icons.Material.Filled.Translate" Size="Size.Small"
                                       Color="Color.Secondary" OnClick="TranslateInEditModeAsync"
                                       Disabled="_isTranslating" />
                    </MudTooltip>
                    @if (_isTranslating)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Secondary" />
                    }
                </div>
            </div>
        }
        else
        {
            <span>@_campaign.Description</span>
            @if (_isPlayerOrAdmin)
            {
                <MudTooltip Text="Beschrijving bewerken">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default"
                                   OnClick="StartEditDescription" Class="ml-1" />
                </MudTooltip>
                <MudTooltip Text="Vertalen naar Nederlands">
                    <MudIconButton Icon="@Icons.Material.Filled.Translate" Size="Size.Small" Color="Color.Default"
                                   OnClick="TranslateAndEditAsync" Disabled="_isTranslating" Class="ml-1" />
                </MudTooltip>
                @if (_isTranslating)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Secondary" Class="ml-1" />
                }
            }
        }
    </MudText>

    @if (!_isEditingDescription)
    {
        <div class="mb-6"></div>
    }

    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="12" sm="6" md="3" Style="display: flex;">
            <MudPaper Elevation="0" Class="pa-4 flex-1" Style="border: 1px solid var(--mud-palette-lines-default); width: 100%;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Startdatum</MudText>
                <MudText Typo="Typo.body1" Style="font-weight: 600;">@_campaign.StartDate.ToString("d MMMM yyyy")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3" Style="display: flex;">
            <MudPaper Elevation="0" Class="pa-4 flex-1" Style="border: 1px solid var(--mud-palette-lines-default); width: 100%;">
                @if (_campaign.EndDate.HasValue)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Einddatum</MudText>
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">
                        @_campaign.EndDate.Value.ToString("d MMMM yyyy")
                    </MudText>
                }
                else if (_nextSession is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Volgende sessie</MudText>
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">
                        @ToBrussels(_nextSession.ScheduledAt).ToString("d MMMM yyyy")
                    </MudText>
                    <MudTooltip Text="@_nextSession.Location" Placement="Placement.Bottom">
                        <MudText Typo="Typo.body2" Color="Color.Primary" Style="font-weight: 600; cursor: default;">
                            @ToBrussels(_nextSession.ScheduledAt).ToString("HH:mm") uur
                        </MudText>
                    </MudTooltip>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Einddatum</MudText>
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">—</MudText>
                }
            </MudPaper>
        </MudItem>
        @if (!string.IsNullOrWhiteSpace(_campaign.Link))
        {
            <MudItem xs="12" sm="6" md="3" Style="display: flex;">
                <MudPaper Elevation="0" Class="pa-4 flex-1" Style="border: 1px solid var(--mud-palette-lines-default); width: 100%;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Meer informatie</MudText>
                    <MudLink Href="@_campaign.Link" Target="_blank" Typo="Typo.body1" Style="display: block;">
                        <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mr-1" Style="vertical-align: middle;" />Bezoeken
                    </MudLink>
                </MudPaper>
            </MudItem>
        }
        <MudItem xs="12" sm="6" md="3" Style="display: flex;">
            <MudPaper Elevation="0" Class="pa-4 flex-1" Style="border: 1px solid var(--mud-palette-lines-default); width: 100%;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Spelers</MudText>
                <div class="d-flex flex-wrap mt-1" style="gap: 4px;">
                    @if (_campaign.Players.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Geen spelers</MudText>
                    }
                    else
                    {
                        @foreach (var player in _campaign.Players)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                @player.Username.CapFirst()
                            </MudChip>
                        }
                    }
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (!string.IsNullOrWhiteSpace(_campaign.ExtensiveInformation))
    {
        <MudPaper Elevation="0" Class="pa-6 mb-6" Style="border: 1px solid var(--mud-palette-lines-default);">
            <MudText Typo="Typo.h6" Style="font-weight: 600;" Class="mb-3">Uitgebreide informatie</MudText>
            <MudText Typo="Typo.body1" Style="white-space: pre-wrap;">@_campaign.ExtensiveInformation</MudText>
        </MudPaper>
    }

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" Style="display: flex;">
            <MudPaper Elevation="0" Class="pa-6 flex-1 d-flex flex-column justify-space-between" Style="border: 1px solid var(--mud-palette-lines-default); width: 100%;">
                <div class="d-flex align-center mb-3" style="gap: 12px;">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">Karakters</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Bekijk en beheer de Karakters van deze campagne.
                        </MudText>
                    </div>
                </div>
                <MudButton Href="@($"/campaigns/{Id}/characters")"
                           Variant="Variant.Filled" Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           FullWidth="true"
                           Style="text-transform: none; font-weight: 600;">
                    Karakters bekijken
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" Style="display: flex;">
            <MudPaper Elevation="0" Class="pa-6 flex-1 d-flex flex-column justify-space-between" Style="border: 1px solid var(--mud-palette-lines-default); width: 100%;">
                <div class="d-flex align-center mb-3" style="gap: 12px;">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Secondary" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">Recaps</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Lees en schrijf sessieverslagen voor deze campagne.
                        </MudText>
                    </div>
                </div>
                <MudButton Href="@($"/campaigns/{Id}/recaps")"
                           Variant="Variant.Filled" Color="Color.Secondary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           FullWidth="true"
                           Style="text-transform: none; font-weight: 600;">
                    Recaps bekijken
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" Style="display: flex;">
            <MudPaper Elevation="0" Class="pa-6 flex-1 d-flex flex-column justify-space-between" Style="border: 1px solid var(--mud-palette-lines-default); width: 100%;">
                <div class="d-flex align-center mb-3" style="gap: 12px;">
                    <MudIcon Icon="@Icons.Material.Filled.Forum" Color="Color.Tertiary" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">Chat</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Chat met de andere spelers van deze campagne.
                        </MudText>
                    </div>
                </div>
                <MudButton Href="@($"/campaigns/{Id}/chat")"
                           Variant="Variant.Filled" Color="Color.Tertiary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           FullWidth="true"
                           Style="text-transform: none; font-weight: 600;">
                    Chat openen
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" Style="display: flex;">
            <MudPaper Elevation="0" Class="pa-6 flex-1 d-flex flex-column justify-space-between" Style="border: 1px solid var(--mud-palette-lines-default); width: 100%;">
                <div class="d-flex align-center mb-3" style="gap: 12px;">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Primary" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">Sessies</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Bekijk en plan de sessies voor deze campagne.
                        </MudText>
                    </div>
                </div>
                <MudButton Href="@($"/campaigns/{Id}/sessions")"
                           Variant="Variant.Filled" Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           FullWidth="true"
                           Style="text-transform: none; font-weight: 600;">
                    Sessies bekijken
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" Style="display: flex;">
            <MudPaper Elevation="0" Class="pa-6 flex-1 d-flex flex-column justify-space-between" Style="border: 1px solid var(--mud-palette-lines-default); width: 100%;">
                <div class="d-flex align-center mb-3" style="gap: 12px;">
                    <MudIcon Icon="@Icons.Material.Filled.StickyNote2" Color="Color.Secondary" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">Notities</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Het prikbord van de campagne. Voeg briefjes toe.
                        </MudText>
                    </div>
                </div>
                <MudButton Href="@($"/campaigns/{Id}/notes")"
                           Variant="Variant.Filled" Color="Color.Secondary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           FullWidth="true"
                           Style="text-transform: none; font-weight: 600;">
                    Notities bekijken
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" Style="display: flex;">
            <MudPaper Elevation="0" Class="pa-6 flex-1 d-flex flex-column justify-space-between" Style="border: 1px solid var(--mud-palette-lines-default); width: 100%;">
                <div class="d-flex align-center mb-3" style="gap: 12px;">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="color:#D4AF37;font-size:2.1875rem;" />
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600; font-family:'Cinzel';">Loreacle</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Stel vragen aan de AI-orakel van je campagne.
                        </MudText>
                    </div>
                </div>
                <MudButton Href="@($"/campaigns/{Id}/loreacle")"
                           Variant="Variant.Filled"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           FullWidth="true"
                           Style="text-transform: none; font-weight: 600; background-color:#2D1A0A; color:#D4AF37;">
                    Loreacle raadplegen
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private static readonly TimeZoneInfo BrusselsZone =
        TimeZoneInfo.FindSystemTimeZoneById("Europe/Brussels");

    private static DateTime ToBrussels(DateTime utc) =>
        TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(utc, DateTimeKind.Utc), BrusselsZone);

    [Parameter] public Guid Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthTask { get; set; }

    private CampaignDto? _campaign;
    private GameSessionDto? _nextSession;
    private bool _loading = true;

    private Guid _currentUserId;
    private bool _isAdmin;
    private bool _isPlayerOrAdmin;
    private Guid? _favoriteCampaignId;

    // Description editing
    private bool _isEditingDescription;
    private string _editDescriptionValue = string.Empty;
    private bool _isSavingDescription;
    private bool _isTranslating;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthTask!;
        Guid.TryParse(authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _currentUserId);
        _isAdmin = authState.User.IsInRole("Admin");

        _campaign = await ApiClient.GetCampaignAsync(Id);
        if (_campaign is not null && !_campaign.EndDate.HasValue)
            _nextSession = await ApiClient.GetNextGameSessionAsync(Id);

        _isPlayerOrAdmin = _isAdmin || (_campaign?.Players.Any(p => p.Id == _currentUserId) ?? false);

        if (!FavoriteCampaignState.IsLoaded)
        {
            var fav = await ApiClient.GetFavoriteCampaignAsync();
            FavoriteCampaignState.Set(fav?.Id, fav?.Title);
        }

        _favoriteCampaignId = FavoriteCampaignState.CampaignId;
        _loading = false;
    }

    private async Task ToggleFavoriteAsync()
    {
        if (_campaign is null) return;
        Guid? newId = _favoriteCampaignId == _campaign.Id ? null : _campaign.Id;
        string? newTitle = newId.HasValue ? _campaign.Title : null;

        await ApiClient.SetFavoriteCampaignAsync(newId);
        _favoriteCampaignId = newId;
        FavoriteCampaignState.Set(newId, newTitle);
    }

    private void StartEditDescription()
    {
        _editDescriptionValue = _campaign?.Description ?? string.Empty;
        _isEditingDescription = true;
    }

    private void CancelEditDescription() => _isEditingDescription = false;

    private async Task SaveDescriptionAsync()
    {
        if (_campaign is null) return;
        _isSavingDescription = true;
        try
        {
            var ok = await ApiClient.UpdateDescriptionAsync(_campaign.Id, _editDescriptionValue);
            if (ok)
            {
                _campaign.Description = _editDescriptionValue;
                _isEditingDescription = false;
                Snackbar.Add("Beschrijving bijgewerkt.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Opslaan mislukt.", Severity.Error);
            }
        }
        finally
        {
            _isSavingDescription = false;
        }
    }

    private async Task TranslateAndEditAsync()
    {
        if (_campaign is null) return;
        _isTranslating = true;
        try
        {
            var translated = await ApiClient.TranslateToNlAsync(_campaign.Description);
            if (translated is not null)
            {
                _editDescriptionValue = translated;
                _isEditingDescription = true;
            }
            else
            {
                Snackbar.Add("Vertaling mislukt.", Severity.Warning);
            }
        }
        finally
        {
            _isTranslating = false;
        }
    }

    private async Task TranslateInEditModeAsync()
    {
        _isTranslating = true;
        try
        {
            var translated = await ApiClient.TranslateToNlAsync(_editDescriptionValue);
            if (translated is not null)
                _editDescriptionValue = translated;
            else
                Snackbar.Add("Vertaling mislukt.", Severity.Warning);
        }
        finally
        {
            _isTranslating = false;
        }
    }
}
