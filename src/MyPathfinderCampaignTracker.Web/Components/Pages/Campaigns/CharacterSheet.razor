@page "/campaigns/{CampaignId:guid}/characters/{CharacterId:guid}/sheet"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@using System.Security.Claims

<PageTitle>Character Sheet — Pathfinder Campaign Tracker</PageTitle>

<MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-4" Icon="@Icons.Material.Filled.Construction">
    <strong>Work in Progress</strong> — This feature is currently under active development. Data may be lost or reset without notice. Do not rely on this character sheet for your sessions yet.
</MudAlert>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_character is null)
{
    <MudText Color="Color.Error">Character not found.</MudText>
}
else
{
    @* ── Header ── *@
    <div class="d-flex align-center mb-4" style="gap: 12px; flex-wrap: wrap;">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default"
                       OnClick="@(() => Navigation.NavigateTo($"/campaigns/{CampaignId}/characters"))" />
        @if (_photoSrc is not null)
        {
            <img src="@_photoSrc" style="width: 64px; height: 64px; border-radius: 50%; flex-shrink: 0;" alt="Avatar" />
        }
        else
        {
            <MudAvatar Color="Color.Primary" Style="width: 64px; height: 64px; font-size: 1.6rem; flex-shrink: 0;">
                @_character.Name.FirstOrDefault()
            </MudAvatar>
        }
        <div style="flex: 1;">
            <div class="d-flex align-center" style="gap: 8px; flex-wrap: wrap;">
                <MudText Typo="Typo.h4" Style="font-weight: 700;">@_character.Name</MudText>
                @if (_character.KilledInAction)
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.Dangerous">KIA</MudChip>
                }
            </div>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                @_character.Race · @_character.CharacterClass · Level @_character.Level
                @if (!string.IsNullOrWhiteSpace(_character.Alignment)) { <text> · @_character.Alignment</text> }
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Player: @_character.OwnerUsername</MudText>
        </div>

        @if (_canEdit)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                       Disabled="_saving" OnClick="SaveSheet" Style="text-transform: none; font-weight: 600;">
                @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Save
            </MudButton>
        }
    </div>

    @* ── HP Quick-Edit (always visible) ── *@
    <MudPaper Elevation="0" Class="pa-3 mb-4 fantasy-card" Style="border-radius: 8px;">
        <MudGrid Spacing="2" Justify="Justify.FlexStart">
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="pf-section-title mb-1">Hit Points</MudText>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_sheet.CurrentHitPoints" Label="Current HP" Variant="Variant.Outlined"
                                 Disabled="!_canEdit" Min="-999" Max="9999" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_sheet.MaxHitPoints" Label="Maximum HP" Variant="Variant.Outlined"
                                 Disabled="!_canEdit" Min="0" Max="9999" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_sheet.TemporaryHitPoints" Label="Temporary HP" Variant="Variant.Outlined"
                                 Disabled="!_canEdit" Min="0" Max="9999" />
            </MudItem>
            <MudItem xs="12">
                @{
                    var hpPercent = _sheet.MaxHitPoints > 0
                        ? Math.Clamp((double)_sheet.CurrentHitPoints / _sheet.MaxHitPoints * 100, 0, 100)
                        : 0;
                    var hpColor = hpPercent > 50 ? Color.Success : hpPercent > 25 ? Color.Warning : Color.Error;
                }
                <MudProgressLinear Value="@hpPercent" Color="@hpColor" Rounded="true" Size="Size.Large" />
                <MudText Typo="Typo.caption" Align="Align.Center" Class="mt-1">
                    @_sheet.CurrentHitPoints / @_sheet.MaxHitPoints HP
                    @if (_sheet.TemporaryHitPoints > 0) { <text> (+@_sheet.TemporaryHitPoints temporary)</text> }
                </MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* ── Tabs ── *@
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" TabPanelClass="pa-4"
             Color="Color.Primary" Class="mb-4">

        @* Tab 1: Combat *@
        <MudTabPanel Text="Combat" Icon="@Icons.Material.Filled.Shield">
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Class="pf-section-title mb-2">Armor Class</MudText>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_sheet.ArmorClass" Label="AC (normal)" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="0" Max="99" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_sheet.TouchArmorClass" Label="AC (touch)" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="0" Max="99" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_sheet.FlatFootedArmorClass" Label="AC (flat-footed)" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="0" Max="99" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-1" />
                    <MudText Typo="Typo.subtitle1" Class="pf-section-title mb-2 mt-2">Movement &amp; Initiative</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_sheet.InitiativeBonus" Label="Initiative Bonus" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="-99" Max="99"
                                     HelperText="@FormatMod(_sheet.InitiativeBonus)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_sheet.Speed" Label="Speed (ft)" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="0" Max="999" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-1" />
                    <MudText Typo="Typo.subtitle1" Class="pf-section-title mb-2 mt-2">Attack</MudText>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_sheet.BaseAttackBonus" Label="Base Attack Bonus (BAB)" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="0" Max="20"
                                     HelperText="@FormatMod(_sheet.BaseAttackBonus)" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_sheet.CombatManeuverBonus" Label="Combat Maneuver Bonus (CMB)" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="-99" Max="99"
                                     HelperText="@FormatMod(_sheet.CombatManeuverBonus)" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_sheet.CombatManeuverDefense" Label="Combat Maneuver Defense (CMD)" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="0" Max="99" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-1" />
                    <MudText Typo="Typo.subtitle1" Class="pf-section-title mb-2 mt-2">Saving Throws</MudText>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_sheet.FortitudeSave" Label="Fortitude (CON)" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="-99" Max="99"
                                     HelperText="@FormatMod(_sheet.FortitudeSave)" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_sheet.ReflexSave" Label="Reflex (DEX)" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="-99" Max="99"
                                     HelperText="@FormatMod(_sheet.ReflexSave)" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_sheet.WillSave" Label="Will (WIS)" Variant="Variant.Outlined"
                                     Disabled="!_canEdit" Min="-99" Max="99"
                                     HelperText="@FormatMod(_sheet.WillSave)" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Tab 2: Skills *@
        <MudTabPanel Text="Skills" Icon="@Icons.Material.Filled.MenuBook">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                Total = Ability mod + Ranks + (3 if class skill with ≥1 rank) + Misc
            </MudText>

            @* Header row *@
            <div class="d-flex align-center mb-1 px-2" style="gap: 8px;">
                <div style="flex: 3; min-width: 0;">
                    <MudText Typo="Typo.caption" Style="font-weight: 700;">Skill</MudText>
                </div>
                <div style="width: 40px; text-align: center;">
                    <MudText Typo="Typo.caption" Style="font-weight: 700;">Mod</MudText>
                </div>
                <div style="width: 56px; text-align: center;">
                    <MudText Typo="Typo.caption" Style="font-weight: 700;">CS</MudText>
                </div>
                <div style="width: 64px; text-align: center;">
                    <MudText Typo="Typo.caption" Style="font-weight: 700;">Ranks</MudText>
                </div>
                <div style="width: 64px; text-align: center;">
                    <MudText Typo="Typo.caption" Style="font-weight: 700;">Misc</MudText>
                </div>
                <div style="width: 52px; text-align: center;">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; color: var(--mud-palette-primary);">Total</MudText>
                </div>
            </div>
            <MudDivider Class="mb-1" />

            @foreach (var skill in _sheet.Skills)
            {
                var total = AbilityModifier(_character, skill.AbilityKey)
                          + skill.Ranks
                          + (skill.IsClassSkill && skill.Ranks > 0 ? 3 : 0)
                          + skill.MiscBonus;
                var isDisabled = !_canEdit || (skill.TrainedOnly && skill.Ranks == 0);

                <div class="d-flex align-center py-1 px-2 skill-row"
                     style="gap: 8px; border-bottom: 1px solid var(--mud-palette-lines-default);">
                    <div style="flex: 3; min-width: 0;">
                        <MudText Typo="Typo.body2" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            @skill.Name
                            @if (skill.TrainedOnly)
                            {
                                <MudTooltip Text="Trained only">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small"
                                             Style="font-size: 0.7rem; color: var(--mud-palette-warning); vertical-align: middle; margin-left: 2px;" />
                                </MudTooltip>
                            }
                        </MudText>
                    </div>
                    <div style="width: 40px; text-align: center;">
                        @{
                            var abilityMod = AbilityModifier(_character, skill.AbilityKey);
                        }
                        <MudText Typo="Typo.caption" Color="@(abilityMod >= 0 ? Color.Success : Color.Error)">
                            @FormatMod(abilityMod)
                        </MudText>
                    </div>
                    <div style="width: 56px; display: flex; justify-content: center;">
                        <MudCheckBox @bind-Value="skill.IsClassSkill" Size="Size.Small"
                                     Color="Color.Primary" Disabled="!_canEdit" />
                    </div>
                    <div style="width: 64px;">
                        <MudNumericField T="int" Value="@skill.Ranks"
                                         ValueChanged="@(v => skill.Ranks = v)"
                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                         Min="0" Max="20" Disabled="!_canEdit"
                                         Style="font-size: 0.8rem;" HideSpinButtons="true" />
                    </div>
                    <div style="width: 64px;">
                        <MudNumericField T="int" Value="@skill.MiscBonus"
                                         ValueChanged="@(v => skill.MiscBonus = v)"
                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                         Min="-99" Max="99" Disabled="!_canEdit"
                                         Style="font-size: 0.8rem;" HideSpinButtons="true" />
                    </div>
                    <div style="width: 52px; text-align: center;">
                        <MudText Typo="Typo.subtitle2"
                                 Style="font-weight: 700; color: var(--mud-palette-primary);">
                            @FormatMod(total)
                        </MudText>
                    </div>
                </div>
            }
        </MudTabPanel>

        @* Tab 3: Equipment *@
        <MudTabPanel Text="Equipment" Icon="@Icons.Material.Filled.Backpack">
            <MudTextField @bind-Value="_sheet.Equipment" Label="Equipment &amp; Gear"
                          Variant="Variant.Outlined" Lines="18"
                          Disabled="!_canEdit"
                          Placeholder="List weapons, armor, magic items, potions, treasure, etc..." />
        </MudTabPanel>

        @* Tab 4: Spells *@
        <MudTabPanel Text="Spells" Icon="@Icons.Material.Filled.AutoAwesome">
            <MudTextField @bind-Value="_sheet.Spells" Label="Spells &amp; Spell Slots"
                          Variant="Variant.Outlined" Lines="18"
                          Disabled="!_canEdit"
                          Placeholder="Known/prepared spells, spell slots per level, concentration bonus..." />
        </MudTabPanel>

        @* Tab 5: Notes *@
        <MudTabPanel Text="Notes" Icon="@Icons.Material.Filled.Notes">
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudTextField @bind-Value="_sheet.Feats" Label="Feats &amp; Abilities"
                                  Variant="Variant.Outlined" Lines="6"
                                  Disabled="!_canEdit"
                                  Placeholder="Feats, combat techniques, racial traits, class features..." />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_sheet.SpecialAbilities" Label="Special Abilities"
                                  Variant="Variant.Outlined" Lines="5"
                                  Disabled="!_canEdit"
                                  Placeholder="Special attacks, ability qualities, supernatural abilities..." />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_sheet.Notes" Label="Session Notes"
                                  Variant="Variant.Outlined" Lines="6"
                                  Disabled="!_canEdit"
                                  Placeholder="Free notes for use during the session..." />
                </MudItem>
            </MudGrid>
        </MudTabPanel>

    </MudTabs>
}

@code {
    [Parameter] public Guid CampaignId { get; set; }
    [Parameter] public Guid CharacterId { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private CharacterDto? _character;
    private CharacterSheetDto _sheet = new();
    private string? _photoSrc;
    private bool _loading = true;
    private bool _saving;
    private bool _canEdit;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        Guid.TryParse(userIdClaim, out var currentUserId);
        var isAdmin = authState.User.IsInRole("Admin");

        _character = await ApiClient.GetCharacterAsync(CharacterId);
        if (_character is null) { _loading = false; return; }

        _canEdit = _character.UserId == currentUserId || isAdmin;

        var photoBytes = _character.HasPhoto ? await ApiClient.GetCharacterPhotoAsync(CharacterId) : null;
        if (photoBytes is not null)
            _photoSrc = $"data:image/png;base64,{Convert.ToBase64String(photoBytes)}";

        var sheet = await ApiClient.GetCharacterSheetAsync(CharacterId);
        if (sheet is not null)
            _sheet = sheet;

        _loading = false;
    }

    private async Task SaveSheet()
    {
        if (_character is null) return;
        _saving = true;
        try
        {
            var request = new CharacterSheetRequest(
                _sheet.MaxHitPoints,
                _sheet.CurrentHitPoints,
                _sheet.TemporaryHitPoints,
                _sheet.ArmorClass,
                _sheet.TouchArmorClass,
                _sheet.FlatFootedArmorClass,
                _sheet.InitiativeBonus,
                _sheet.Speed,
                _sheet.BaseAttackBonus,
                _sheet.CombatManeuverBonus,
                _sheet.CombatManeuverDefense,
                _sheet.FortitudeSave,
                _sheet.ReflexSave,
                _sheet.WillSave,
                _sheet.Skills.Select(s => new SkillEntryRequest(
                    s.Name, s.AbilityKey, s.IsClassSkill, s.Ranks, s.MiscBonus, s.TrainedOnly)).ToList(),
                _sheet.Feats,
                _sheet.SpecialAbilities,
                _sheet.Equipment,
                _sheet.Spells,
                _sheet.Notes);

            var ok = await ApiClient.UpdateCharacterSheetAsync(CharacterId, request);
            Snackbar.Add(ok ? "Character sheet saved." : "Save failed.", ok ? Severity.Success : Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private static int AbilityModifier(CharacterDto c, string key) => key switch
    {
        "STR" => Mod(c.Strength),
        "DEX" => Mod(c.Dexterity),
        "CON" => Mod(c.Constitution),
        "INT" => Mod(c.Intelligence),
        "WIS" => Mod(c.Wisdom),
        "CHA" => Mod(c.Charisma),
        _     => 0
    };

    private static int Mod(int score) => (int)Math.Floor((score - 10) / 2.0);

    private static string FormatMod(int value) => value >= 0 ? $"+{value}" : value.ToString();
}
