@page "/my/recaps"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Mijn Terugblikken — Pathfinder Campaign Tracker</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else
{
    <MudText Typo="Typo.h4" Class="mb-1 pf-section-title">Mijn Terugblikken</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
        Terugblikken die u heeft geschreven, van meest recent naar minst recent.
    </MudText>

    @if (_recaps.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center"
                  Style="border: 1px dashed var(--mud-palette-lines-default);">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">U heeft nog geen terugblikken geschreven</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Ga naar een campagne om uw eerste terugblik toe te voegen.</MudText>
        </MudPaper>
    }
    else
    {
        <div class="d-flex flex-column" style="gap: 16px;">
            @foreach (var recap in _recaps)
            {
                <MudPaper Elevation="0" Class="pa-6 card-hover fantasy-card">
                    <div class="d-flex align-start justify-space-between flex-wrap" style="gap: 8px;">
                        <div style="flex: 1; min-width: 0;">
                            <div class="d-flex align-center flex-wrap mb-1" style="gap: 10px;">
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small"
                                         Variant="Variant.Filled" Style="font-weight: 700;">
                                    Terugblik @recap.Number
                                </MudChip>
                                <MudText Typo="Typo.h6" Style="font-weight: 700;">@recap.Title</MudText>
                            </div>

                            <div class="d-flex align-center flex-wrap mb-3" style="gap: 12px;">
                                <div class="d-flex align-center" style="gap: 4px;">
                                    <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Small" Color="Color.Secondary" />
                                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                                               Style="padding: 0; min-width: 0; text-transform: none;"
                                               OnClick="@(() => Navigation.NavigateTo($"/campaigns/{recap.CampaignId}/recaps"))">
                                        @recap.CampaignName
                                    </MudButton>
                                </div>
                                <div class="d-flex align-center" style="gap: 4px;">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @recap.Date.ToString("d MMMM yyyy")
                                    </MudText>
                                </div>
                            </div>

                            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="white-space: pre-wrap; line-height: 1.7;">
                                @(recap.Contents.Length > 300 ? recap.Contents[..300] + "…" : recap.Contents)
                            </MudText>
                        </div>

                        <MudTooltip Text="Bekijk terugblikken van deze campagne">
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                           Color="Color.Primary" Size="Size.Small"
                                           OnClick="@(() => Navigation.NavigateTo($"/campaigns/{recap.CampaignId}/recaps"))" />
                        </MudTooltip>
                    </div>
                </MudPaper>
            }
        </div>
    }
}

@code {
    private List<RecapDto> _recaps = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _recaps = await ApiClient.GetMyRecapsAsync();
        _loading = false;
    }
}
