@page "/my/campaigns"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Mijn Campagnes — Pathfinder Campaign Tracker</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else
{
    <MudText Typo="Typo.h4" Class="mb-1 pf-section-title">Mijn Campagnes</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
        Campagnes waar u aan deelneemt, van meest recent naar minst recent.
    </MudText>

    @if (_campaigns.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center"
                  Style="border: 1px dashed var(--mud-palette-lines-default);">
            <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">U neemt nog niet deel aan campagnes</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Een beheerder kan u toevoegen aan een campagne.</MudText>
        </MudPaper>
    }
    else
    {
        <div class="d-flex flex-column" style="gap: 16px;">
            @foreach (var campaign in _campaigns)
            {
                <MudPaper Elevation="0" Class="pa-6 card-hover fantasy-card">
                    <div class="d-flex align-start justify-space-between flex-wrap" style="gap: 12px;">
                        <div style="flex: 1; min-width: 0;">
                            <div class="d-flex align-center mb-1" style="gap: 8px;">
                                <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Primary" Size="Size.Small" />
                                <MudText Typo="Typo.h6" Style="font-weight: 700;">@campaign.Title</MudText>
                                @if (campaign.EndDate.HasValue && campaign.EndDate < DateTime.Today)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                        Afgerond
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                        Actief
                                    </MudChip>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(campaign.Description))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                                    @(campaign.Description.Length > 160 ? campaign.Description[..160] + "…" : campaign.Description)
                                </MudText>
                            }

                            <div class="d-flex align-center flex-wrap mb-2" style="gap: 12px;">
                                <div class="d-flex align-center" style="gap: 4px;">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @campaign.StartDate.ToString("d MMMM yyyy")
                                        @if (campaign.EndDate.HasValue)
                                        { <text> – @campaign.EndDate.Value.ToString("d MMMM yyyy")</text> }
                                    </MudText>
                                </div>
                                <div class="d-flex align-center" style="gap: 4px;">
                                    <MudIcon Icon="@Icons.Material.Filled.Update" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Bijgewerkt: @campaign.UpdatedAt.ToLocalTime().ToString("d MMM yyyy")
                                    </MudText>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap" style="gap: 4px;">
                                @foreach (var player in campaign.Players)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                        @player.Username
                                    </MudChip>
                                }
                            </div>
                        </div>

                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   EndIcon="@Icons.Material.Filled.ArrowForward"
                                   OnClick="@(() => Navigation.NavigateTo($"/campaigns/{campaign.Id}"))">
                            Openen
                        </MudButton>
                    </div>
                </MudPaper>
            }
        </div>
    }
}

@code {
    private List<CampaignDto> _campaigns = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _campaigns = await ApiClient.GetMyCampaignsAsync();
        _loading = false;
    }
}
