@page "/my/characters"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Mijn Personages — Pathfinder Campaign Tracker</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else
{
    <MudText Typo="Typo.h4" Class="mb-1 pf-section-title">Mijn Personages</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
        Uw personages gegroepeerd per campagne — levenden eerst, gevallenen als laatste.
    </MudText>

    @if (_groups.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center"
                  Style="border: 1px dashed var(--mud-palette-lines-default);">
            <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">U heeft nog geen personages</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Ga naar een campagne om uw eerste personage aan te maken.</MudText>
        </MudPaper>
    }
    else
    {
        @foreach (var group in _groups)
        {
            <div class="mb-6">
                <div class="d-flex align-center justify-space-between mb-3">
                    <div class="d-flex align-center" style="gap: 8px;">
                        <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.h6" Class="pf-section-title" Style="font-weight: 700;">
                            @group.CampaignName
                        </MudText>
                    </div>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                               EndIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="@(() => Navigation.NavigateTo($"/campaigns/{group.CampaignId}/characters"))">
                        Bekijk alle
                    </MudButton>
                </div>

                <MudGrid Spacing="3">
                    @foreach (var character in group.Characters)
                    {
                        <MudItem xs="12" md="6" xl="4">
                            <MudPaper Elevation="0" Class="@GetCharacterCardClass(character)"
                                      Style="@(character.KilledInAction ? "border: 1px solid var(--mud-palette-lines-default); opacity: 0.75;" : "")">
                                <div class="d-flex align-center justify-space-between mb-2">
                                    <div>
                                        <div class="d-flex align-center" style="gap: 8px;">
                                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@character.Name</MudText>
                                            @if (character.KilledInAction)
                                            {
                                                <MudChip T="string" Color="Color.Error" Size="Size.Small"
                                                         Icon="@Icons.Material.Filled.Dangerous">KIA</MudChip>
                                            }
                                        </div>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @character.Race · @character.CharacterClass · Niveau @character.Level
                                        </MudText>
                                    </div>
                                    <div class="d-flex align-center" style="gap: 0;">
                                        <MudIcon Icon="@(character.KilledInAction ? Icons.Material.Filled.HeartBroken : Icons.Material.Filled.Shield)"
                                                 Color="@(character.KilledInAction ? Color.Error : Color.Primary)"
                                                 Size="Size.Medium" />
                                        <MudTooltip Text="Bewerken">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                           Color="Color.Primary" OnClick="@(() => OpenEditDialog(character))" />
                                        </MudTooltip>
                                        <MudTooltip Text="Verwijderen">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                           Color="Color.Error" OnClick="@(() => OpenDeleteDialog(character))" />
                                        </MudTooltip>
                                    </div>
                                </div>

                                <div class="d-flex justify-space-between" style="gap: 4px;">
                                    @foreach (var (label, score) in AbilityScores(character))
                                    {
                                        <div class="d-flex flex-column align-center pa-1"
                                             style="border: 1px solid var(--mud-palette-lines-default); border-radius: 6px; flex: 1;">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;">@label</MudText>
                                            <MudText Typo="Typo.subtitle2" Style="font-weight: 700; line-height: 1.2;">@score</MudText>
                                            <MudText Typo="Typo.caption" Color="@(Modifier(score) >= 0 ? Color.Success : Color.Error)">
                                                @(Modifier(score) >= 0 ? $"+{Modifier(score)}" : Modifier(score).ToString())
                                            </MudText>
                                        </div>
                                    }
                                </div>

                                @if (!string.IsNullOrWhiteSpace(character.Backstory))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2" Style="font-style: italic;">
                                        @(character.Backstory.Length > 80 ? character.Backstory[..80] + "..." : character.Backstory)
                                    </MudText>
                                }
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </div>
        }
    }
}

@* --- Edit Dialog --- *@
<MudDialog @bind-Visible="_dialogOpen" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Personage bewerken</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Name" Label="Naam" Variant="Variant.Outlined"
                              Required="true" MaxLength="200" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Race" Label="Ras" Variant="Variant.Outlined"
                              Required="true" MaxLength="100" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.CharacterClass" Label="Klasse" Variant="Variant.Outlined"
                              Required="true" MaxLength="100" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_form.Level" Label="Niveau" Variant="Variant.Outlined"
                                 Min="1" Max="20" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Backstory" Label="Achtergrond" Variant="Variant.Outlined"
                              Lines="3" />
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-1" />
                <MudText Typo="Typo.subtitle2" Class="mt-2 mb-2">Vermogensscores</MudText>
            </MudItem>

            @foreach (var (label, prop) in AbilityScoreFields())
            {
                <MudItem xs="6" sm="4">
                    <MudNumericField T="int" Label="@label" Variant="Variant.Outlined"
                                     Min="1" Max="30"
                                     Value="@prop.Getter(_form)"
                                     ValueChanged="@(v => prop.Setter(_form, v))"
                                     HelperText="@AbilityHelperText(prop.Getter(_form))" />
                </MudItem>
            }

            <MudItem xs="12">
                <MudDivider Class="my-1" />
                <MudSwitch @bind-Value="_form.KilledInAction" Label="Gedood in actie (KIA)"
                           Color="Color.Error" Class="mt-1" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog" Variant="Variant.Text" Style="text-transform: none;">Annuleren</MudButton>
        <MudButton OnClick="SaveCharacter" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="_saving" Style="text-transform: none; font-weight: 600;">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Opslaan
        </MudButton>
    </DialogActions>
</MudDialog>

@* --- Delete Confirm Dialog --- *@
<MudDialog @bind-Visible="_deleteDialogOpen" Options="_deleteDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Personage verwijderen</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Weet u zeker dat u <strong>@_deletingCharacter?.Name</strong> wilt verwijderen?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _deleteDialogOpen = false)" Variant="Variant.Text"
                   Style="text-transform: none;">Annuleren</MudButton>
        <MudButton OnClick="ConfirmDelete" Variant="Variant.Filled" Color="Color.Error"
                   Disabled="_saving" Style="text-transform: none; font-weight: 600;">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Verwijderen
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<CharacterGroup> _groups = [];
    private bool _loading = true;

    private bool _dialogOpen;
    private Guid? _editingId;
    private CharacterFormModel _form = new();
    private bool _saving;

    private bool _deleteDialogOpen;
    private CharacterDto? _deletingCharacter;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    private readonly DialogOptions _deleteDialogOptions = new()
    {
        MaxWidth = MaxWidth.ExtraSmall,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadCharactersAsync();
        _loading = false;
    }

    private async Task LoadCharactersAsync()
    {
        var characters = await ApiClient.GetMyCharactersAsync();

        _groups = characters
            .GroupBy(c => new { c.CampaignId, c.CampaignName })
            .OrderBy(g => g.Key.CampaignName)
            .Select(g => new CharacterGroup
            {
                CampaignId = g.Key.CampaignId,
                CampaignName = g.Key.CampaignName,
                Characters = g
                    .OrderBy(c => c.KilledInAction)
                    .ThenBy(c => c.Name)
                    .ToList()
            })
            .ToList();
    }

    private void OpenEditDialog(CharacterDto character)
    {
        _editingId = character.Id;
        _form = new CharacterFormModel
        {
            Name = character.Name,
            Race = character.Race,
            CharacterClass = character.CharacterClass,
            Level = character.Level,
            Backstory = character.Backstory,
            Strength = character.Strength,
            Dexterity = character.Dexterity,
            Constitution = character.Constitution,
            Intelligence = character.Intelligence,
            Wisdom = character.Wisdom,
            Charisma = character.Charisma,
            KilledInAction = character.KilledInAction
        };
        _dialogOpen = true;
    }

    private void CloseDialog() => _dialogOpen = false;

    private async Task SaveCharacter()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            Snackbar.Add("Naam is verplicht.", Severity.Warning);
            return;
        }

        if (!_editingId.HasValue) return;

        _saving = true;
        try
        {
            var request = new CharacterRequest(
                _form.Name.Trim(),
                _form.Race.Trim(),
                _form.CharacterClass.Trim(),
                _form.Level,
                _form.Backstory.Trim(),
                _form.Strength,
                _form.Dexterity,
                _form.Constitution,
                _form.Intelligence,
                _form.Wisdom,
                _form.Charisma,
                _form.KilledInAction);

            var ok = await ApiClient.UpdateCharacterAsync(_editingId.Value, request);
            Snackbar.Add(ok ? "Personage bijgewerkt." : "Bijwerken mislukt.", ok ? Severity.Success : Severity.Error);

            _dialogOpen = false;
            await LoadCharactersAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private void OpenDeleteDialog(CharacterDto character)
    {
        _deletingCharacter = character;
        _deleteDialogOpen = true;
    }

    private async Task ConfirmDelete()
    {
        if (_deletingCharacter is null) return;
        _saving = true;
        try
        {
            var ok = await ApiClient.DeleteCharacterAsync(_deletingCharacter.Id);
            _deleteDialogOpen = false;
            Snackbar.Add(ok ? "Personage verwijderd." : "Verwijderen mislukt.", ok ? Severity.Success : Severity.Error);
            if (ok) await LoadCharactersAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private static int Modifier(int score) => (int)Math.Floor((score - 10) / 2.0);

    private static string AbilityHelperText(int score)
    {
        var mod = Modifier(score);
        return $"Modifier: {(mod >= 0 ? "+" : "")}{mod}";
    }

    private static string GetCharacterCardClass(CharacterDto character) =>
        character.KilledInAction ? "pa-4 card-hover" : "pa-4 card-hover fantasy-card";

    private static IEnumerable<(string Label, int Score)> AbilityScores(CharacterDto c) =>
    [
        ("STR", c.Strength),
        ("DEX", c.Dexterity),
        ("CON", c.Constitution),
        ("INT", c.Intelligence),
        ("WIS", c.Wisdom),
        ("CHA", c.Charisma)
    ];

    private record AbilityFieldProp(Func<CharacterFormModel, int> Getter, Action<CharacterFormModel, int> Setter);

    private static IEnumerable<(string Label, AbilityFieldProp Prop)> AbilityScoreFields() =>
    [
        ("STR", new(m => m.Strength,    (m, v) => m.Strength    = v)),
        ("DEX", new(m => m.Dexterity,   (m, v) => m.Dexterity   = v)),
        ("CON", new(m => m.Constitution,(m, v) => m.Constitution = v)),
        ("INT", new(m => m.Intelligence,(m, v) => m.Intelligence = v)),
        ("WIS", new(m => m.Wisdom,      (m, v) => m.Wisdom       = v)),
        ("CHA", new(m => m.Charisma,    (m, v) => m.Charisma     = v))
    ];

    private class CharacterFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string Race { get; set; } = string.Empty;
        public string CharacterClass { get; set; } = string.Empty;
        public int Level { get; set; } = 1;
        public string Backstory { get; set; } = string.Empty;
        public int Strength { get; set; } = 10;
        public int Dexterity { get; set; } = 10;
        public int Constitution { get; set; } = 10;
        public int Intelligence { get; set; } = 10;
        public int Wisdom { get; set; } = 10;
        public int Charisma { get; set; } = 10;
        public bool KilledInAction { get; set; }
    }

    private record CharacterGroup
    {
        public Guid CampaignId { get; init; }
        public string CampaignName { get; init; } = string.Empty;
        public List<CharacterDto> Characters { get; init; } = [];
    }
}
