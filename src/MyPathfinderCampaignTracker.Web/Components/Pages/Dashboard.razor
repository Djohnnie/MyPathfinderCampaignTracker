@page "/dashboard"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ApiClient ApiClient

<PageTitle>Dashboard — Pathfinder Campaign Tracker</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1" Style="font-weight: 700;">Dashboard</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">Uw Pathfinder Campaign Tracker</MudText>

<AuthorizeView>
    <Authorized>
        <MudPaper Elevation="0" Class="pa-6 mb-6 card-hover" Style="border: 1px solid var(--mud-palette-lines-default);">
            <MudText Typo="Typo.h5" Class="mb-1" Style="font-weight: 600;">
                Welkom terug, <strong>@context.User.Identity?.Name</strong>!
            </MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                Uw Pathfinder Campaign Tracker is klaar voor gebruik.
            </MudText>
        </MudPaper>

        @if (_latestCampaign is not null)
        {
            <MudText Typo="Typo.h6" Style="font-weight: 600;" Class="mb-3">Laatste campagne</MudText>
            <MudPaper Elevation="0" Class="pa-6 mb-6 card-hover" Style="border: 1px solid var(--mud-palette-primary-default, #2563eb);">
                <div class="d-flex align-center justify-space-between flex-wrap" style="gap: 12px;">
                    <div>
                        <div class="d-flex align-center mb-1" style="gap: 8px;">
                            <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Primary" />
                            <MudText Typo="Typo.h6" Style="font-weight: 600;">@_latestCampaign.Title</MudText>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_latestCampaign.Description))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                                @(_latestCampaign.Description.Length > 120 ? _latestCampaign.Description[..120] + "…" : _latestCampaign.Description)
                            </MudText>
                        }
                        <div class="d-flex flex-wrap" style="gap: 4px;">
                            @foreach (var player in _latestCampaign.Players)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                    @player.Username
                                </MudChip>
                            }
                        </div>
                    </div>
                    <MudButton Href="@($"/campaigns/{_latestCampaign.Id}")"
                               Variant="Variant.Filled" Color="Color.Primary"
                               EndIcon="@Icons.Material.Filled.ArrowForward"
                               Style="text-transform: none; font-weight: 600;">
                        Openen
                    </MudButton>
                </div>
            </MudPaper>
        }

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-6 card-hover" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Large" Color="Color.Primary" Class="mb-3" />
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Campagnes</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Beheer uw campagnes</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-6 card-hover" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Personages</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Volg uw gezelschap</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-6 card-hover" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Large" Color="Color.Tertiary" Class="mb-3" />
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Sessies</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Leg sessienotities vast</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </Authorized>
</AuthorizeView>

@code {
    private CampaignDto? _latestCampaign;

    protected override async Task OnInitializedAsync()
    {
        var campaigns = await ApiClient.GetCampaignsAsync();
        _latestCampaign = campaigns.MaxBy(c => c.UpdatedAt);
    }
}

