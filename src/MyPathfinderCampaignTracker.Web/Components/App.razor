    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64," />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="_content/MudX.MudBlazor.Extension/mudx.min.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        window.chatScrollToBottom = function () {
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
        };
        window.loreacleScrollToBottom = function (element) {
            if (element) { element.scrollTop = element.scrollHeight; }
        };
        window.addBodyClass = function (cls) { document.body.classList.add(cls); };
        window.removeBodyClass = function (cls) { document.body.classList.remove(cls); };
    </script>
</body>

</html>
