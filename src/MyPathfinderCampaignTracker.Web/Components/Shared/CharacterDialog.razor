@using Microsoft.AspNetCore.Components.Forms

<MudDialog Visible="IsOpen" VisibleChanged="OnVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(EditingId.HasValue ? "Personage bewerken" : "Nieuw personage")</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Personagefoto (optioneel)</MudText>
                <div class="d-flex align-center" style="gap: 16px; flex-wrap: wrap;">
                    @if (SelectedPhoto is not null)
                    {
                        <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small">
                            @SelectedPhoto.Name
                        </MudChip>
                    }
                    else if (EditingId.HasValue && PhotoCache.TryGetValue(EditingId.Value, out var existingPhoto) && existingPhoto is not null)
                    {
                        <img src="@existingPhoto" style="width: 48px; height: 48px; border-radius: 50%;" alt="Huidige foto" />
                    }
                    <MudFileUpload T="IBrowserFile" FilesChanged="OnPhotoSelected" Accept="image/*">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PhotoCamera"
                                       Size="Size.Small" Style="text-transform: none;">
                                @(SelectedPhoto is not null ? "Andere foto kiezen" : "Foto kiezen")
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                </div>
                <MudDivider Class="mt-3" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Form.Name" Label="Naam" Variant="Variant.Outlined"
                              Required="true" MaxLength="200" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Form.Race" Label="Ras" Variant="Variant.Outlined"
                              Required="true" MaxLength="100" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Form.CharacterClass" Label="Klasse" Variant="Variant.Outlined"
                              Required="true" MaxLength="100" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="Form.Level" Label="Niveau" Variant="Variant.Outlined"
                                 Min="1" Max="20" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Form.Backstory" Label="Achtergrond" Variant="Variant.Outlined"
                              Lines="3" />
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-1" />
                <MudText Typo="Typo.subtitle2" Class="mt-2 mb-2">Vermogensscores</MudText>
            </MudItem>

            @foreach (var (label, prop) in AbilityScoreFields())
            {
                <MudItem xs="6" sm="4">
                    <MudNumericField T="int" Label="@label" Variant="Variant.Outlined"
                                     Min="1" Max="30"
                                     Value="@prop.Getter(Form)"
                                     ValueChanged="@(v => prop.Setter(Form, v))"
                                     HelperText="@AbilityHelperText(prop.Getter(Form))" />
                </MudItem>
            }

            <MudItem xs="12">
                <MudDivider Class="my-1" />
                <MudSwitch @bind-Value="Form.KilledInAction" Label="Gedood in actie (KIA)"
                           Color="Color.Error" Class="mt-1" />
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2" Class="mt-2 mb-2">Verhaal &amp; Persoonlijkheid (optioneel)</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="Form.Alignment" Label="Gezindheid" Variant="Variant.Outlined"
                           Clearable="true" T="string">
                    <MudSelectItem T="string" Value="@("Wettig Goed")">Wettig Goed</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Neutraal Goed")">Neutraal Goed</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Chaotisch Goed")">Chaotisch Goed</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Wettig Neutraal")">Wettig Neutraal</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Waar Neutraal")">Waar Neutraal</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Chaotisch Neutraal")">Chaotisch Neutraal</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Wettig Kwaad")">Wettig Kwaad</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Neutraal Kwaad")">Neutraal Kwaad</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Chaotisch Kwaad")">Chaotisch Kwaad</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Form.Languages" Label="Talen" Variant="Variant.Outlined"
                              MaxLength="200" Placeholder="bv. Gemeen, Elfs, Dwergisch" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Form.Appearance" Label="Uiterlijk" Variant="Variant.Outlined"
                              Lines="2" MaxLength="500" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Form.Personality" Label="Persoonlijkheid" Variant="Variant.Outlined"
                              Lines="2" MaxLength="500" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Form.IdealsAndGoals" Label="Idealen &amp; Doelen" Variant="Variant.Outlined"
                              Lines="2" MaxLength="500" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Form.Flaws" Label="Tekortkomingen" Variant="Variant.Outlined"
                              Lines="2" MaxLength="500" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="HandleClose" Variant="Variant.Text" Style="text-transform: none;">Annuleren</MudButton>
        <MudButton OnClick="HandleSave" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="Saving" Style="text-transform: none; font-weight: 600;">
            @if (Saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Opslaan
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public Guid? EditingId { get; set; }
    [Parameter] public CharacterFormModel Form { get; set; } = new();
    [Parameter] public bool Saving { get; set; }
    [Parameter] public IBrowserFile? SelectedPhoto { get; set; }
    [Parameter] public EventCallback<IBrowserFile?> SelectedPhotoChanged { get; set; }
    [Parameter] public Dictionary<Guid, string?> PhotoCache { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    private async Task OnVisibleChanged(bool value)
    {
        await IsOpenChanged.InvokeAsync(value);
        if (!value) await OnClose.InvokeAsync();
    }

    private async Task HandleClose()
    {
        await IsOpenChanged.InvokeAsync(false);
        await OnClose.InvokeAsync();
    }

    private async Task HandleSave() => await OnSave.InvokeAsync();

    private async Task OnPhotoSelected(IBrowserFile? file) =>
        await SelectedPhotoChanged.InvokeAsync(file);

    private static int Modifier(int score) => (int)Math.Floor((score - 10) / 2.0);

    private static string AbilityHelperText(int score)
    {
        var mod = Modifier(score);
        return $"Modifier: {(mod >= 0 ? "+" : "")}{mod}";
    }

    private record AbilityFieldProp(Func<CharacterFormModel, int> Getter, Action<CharacterFormModel, int> Setter);

    private static IEnumerable<(string Label, AbilityFieldProp Prop)> AbilityScoreFields() =>
    [
        ("STR", new(m => m.Strength,    (m, v) => m.Strength    = v)),
        ("DEX", new(m => m.Dexterity,   (m, v) => m.Dexterity   = v)),
        ("CON", new(m => m.Constitution,(m, v) => m.Constitution = v)),
        ("INT", new(m => m.Intelligence,(m, v) => m.Intelligence = v)),
        ("WIS", new(m => m.Wisdom,      (m, v) => m.Wisdom       = v)),
        ("CHA", new(m => m.Charisma,    (m, v) => m.Charisma     = v))
    ];

    public class CharacterFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string Race { get; set; } = string.Empty;
        public string CharacterClass { get; set; } = string.Empty;
        public int Level { get; set; } = 1;
        public string Backstory { get; set; } = string.Empty;
        public int Strength { get; set; } = 10;
        public int Dexterity { get; set; } = 10;
        public int Constitution { get; set; } = 10;
        public int Intelligence { get; set; } = 10;
        public int Wisdom { get; set; } = 10;
        public int Charisma { get; set; } = 10;
        public bool KilledInAction { get; set; }
        public string? Alignment { get; set; }
        public string? Personality { get; set; }
        public string? IdealsAndGoals { get; set; }
        public string? Flaws { get; set; }
        public string? Languages { get; set; }
        public string? Appearance { get; set; }
    }
}
