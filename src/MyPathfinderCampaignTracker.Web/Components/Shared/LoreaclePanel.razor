@inject ApiClient ApiClient
@inject IJSRuntime JS

<div class="loreacle-wrapper @(_isOpen ? "loreacle-open" : "")">

    <div class="loreacle-tab" @onclick="@(() => _isOpen = !_isOpen)" title="Loreacle">
        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="color:#D4AF37;font-size:1.2rem;" />
        <span class="loreacle-tab-label">Loreacle</span>
        <MudIcon Icon="@(_isOpen ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ChevronLeft)"
                 Style="color:#F5E6C8;font-size:1rem;margin-top:auto;" />
    </div>

    <div class="loreacle-panel">

        <div class="loreacle-header">
            <MudStack Row AlignItems="AlignItems.Center" Class="pa-3" Spacing="0">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="color:#D4AF37;" Class="mr-2" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1"
                             Style="font-family:'Cinzel';font-weight:700;color:#F5E6C8;line-height:1.2;">
                        Loreacle
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Success" Style="line-height:1.2;">Online</MudText>
                </MudStack>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               Style="color:#F5E6C8;"
                               OnClick="@(() => _isOpen = false)" />
            </MudStack>
            <MudDivider />
        </div>

        <div class="loreacle-messages" @ref="_messagesDiv">
            @if (_messages.Count == 0)
            {
                <div class="d-flex flex-column align-center justify-center pa-4 mt-4">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome"
                             Color="Color.Secondary" Size="Size.Large" Class="mb-2" />
                    <MudText Align="Align.Center" Typo="Typo.body2" Color="Color.Secondary"
                             Style="font-family:'Crimson Text';font-style:italic;">
                        Spreek tot de Loreacle en ontrafel de geheimen van je campagne...
                    </MudText>
                </div>
            }

            @foreach (var msg in _messages)
            {
                <MudXChat Dense="true" Class="mb-2"
                          ChatPosition="@(msg.IsUser ? ChatBubblePosition.End : ChatBubblePosition.Start)"
                          Color="@(msg.IsUser ? Color.Primary : Color.Default)"
                          Variant="Variant.Filled"
                          Elevation="0">
                    @foreach (var part in msg.Content.Split("[BR]", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                    {
                        <MudXChatBubble>@part</MudXChatBubble>
                    }
                </MudXChat>
            }

            @if (_isThinking)
            {
                <MudXChat Dense="true" Class="mb-2" ChatPosition="ChatBubblePosition.Start"
                          Color="Color.Default" Variant="Variant.Filled" Elevation="0">
                    <MudXChatBubble>
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    </MudXChatBubble>
                </MudXChat>
            }

            <div @ref="_scrollAnchor"></div>
        </div>

        <div class="loreacle-input">
            <MudDivider />
            <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Class="pa-2">
                <MudTextField @bind-Value="_input"
                              @onkeydown="OnKeyDown"
                              Placeholder="Vraag de Loreacle..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="flex-grow-1"
                              Immediate="true"
                              Lines="1"
                              Disabled="_isThinking" />
                <MudIconButton Icon="@Icons.Material.Filled.Send"
                               Color="Color.Primary"
                               OnClick="SendAsync"
                               Disabled="@(string.IsNullOrWhiteSpace(_input) || _isThinking)" />
            </MudStack>
        </div>

    </div>
</div>

@code {
    [Parameter] public Guid CampaignId { get; set; }

    private bool _isOpen;
    private bool _isThinking;
    private string _input = string.Empty;
    private List<(bool IsUser, string Content)> _messages = [];
    private ElementReference _messagesDiv;
    private ElementReference _scrollAnchor;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendAsync();
    }

    private async Task SendAsync()
    {
        var userMessage = _input.Trim();
        if (string.IsNullOrWhiteSpace(userMessage) || _isThinking) return;

        _input = string.Empty;
        _messages.Add((true, userMessage));
        _isThinking = true;
        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            var history = _messages
                .Take(_messages.Count - 1)
                .Select(m => new LoreacleMessageDto(m.IsUser, m.Content))
                .ToList();

            var reply = await ApiClient.ChatWithLoreacleAsync(
                CampaignId, new LoreacleRequest(userMessage, history));

            _messages.Add((false, reply ?? "De Loreacle antwoordt niet..."));
        }
        catch
        {
            _messages.Add((false, "Er is iets misgegaan. Probeer het opnieuw."));
        }
        finally
        {
            _isThinking = false;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("loreacleScrollToBottom", _messagesDiv);
        }
        catch { /* ignore during prerender */ }
    }
}
